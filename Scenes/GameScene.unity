  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 226038749}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5135288ba00030e4a9c620ea5c3191ad, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _tutorialPanel: {fileID: 371942759}
  _tutorialText: {fileID: 1817221578}
  _stepCounterText: {fileID: 787711215}
  _arrowImage: {fileID: 0}
  _nextButton: {fileID: 1330809125}
  _skipButton: {fileID: 766376340}
  _steps:
  - "\U0001F943 Welcome to Whiskeyville! You're about to build a distillery empire.\n\nPress
    [B] or tap the Build button to open your building menu."
  - "\U0001F33D Place a Corn Field on the green land.\n\nSelect 'Corn Field' from
    the build panel, then tap a green tile to plant it."
  - "\U0001F33E Your corn is growing! Come back when it's fully grown \u2014 then
    click it to harvest.\n\nLook for the golden shimmer when it's ready."
  - "\U0001FAA3 Build a Mash Tun to process your corn into mash.\n\nThe Mash Tun
    automatically uses your corn. Just build it and watch it work!"
  - "\U0001F525 Build a Still to distill your mash into whiskey.\n\nThe Still needs
    mash from your Mash Tun. Place it and let the chain flow."
  - "\U0001FAB5 Build a Cooperage to make barrels.\n\nYou'll need wood (chop trees
    with the Axe tool) to make barrels for aging."
  - "\U0001F3DA\uFE0F Build a Rickhouse to age your whiskey.\n\nWhiskey + Barrel
    go in \u2192 Aged Whiskey comes out. Patience makes it better."
  - "\U0001F37A Build a Saloon and sell your first whiskey!\n\nClick the Saloon to
    open the sell panel. This is what it's all about.\n\nYou're a distiller now.
    Welcome to the craft. \U0001F943"
  _autoStartOnNewGame: 1
  _showSkipButton: 1
